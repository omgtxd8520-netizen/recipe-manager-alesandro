# Copiar este archivo como .env y ajustar valores si es necesario.
# No se sube al repositorio (ver .gitignore).

# Cadena de conexión a MongoDB
MONGO_URI=mongodb://mongo:27017/recipe_db

# Nombre de la base de datos
MONGO_DB_NAME=recipe_db

# Poner en 1 para usar mongomock en lugar de una conexión real
# (útil para correr tests unitarios sin Docker)
MONGO_USE_MOCK=0
